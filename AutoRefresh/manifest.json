{
  "manifest_version": 3,
  "name": "Auto Refresh",
  "version": "1.0",
  "description": "지정한 시간 간격으로 페이지를 자동 새로고침합니다.",
  "permissions": ["alarms", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
